ANTHROPIC_API_KEY=your_api_key_here

# Database — default uses a local SQLite file
# For Docker, override with:  sqlite+aiosqlite:////data/logistics.db
DATABASE_URL=sqlite+aiosqlite:///./logistics.db

APP_ENV=development
LOG_LEVEL=INFO

# Set to "true" to seed sample data on first startup (Docker entrypoint uses this)
SEED_ON_EMPTY=true
